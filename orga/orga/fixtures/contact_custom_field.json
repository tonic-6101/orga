[
  {
    "doctype": "Custom Field",
    "dt": "Contact",
    "fieldname": "orga_client_section",
    "fieldtype": "Section Break",
    "label": "Orga Client",
    "insert_after": "department",
    "collapsible": 1
  },
  {
    "doctype": "Custom Field",
    "dt": "Contact",
    "fieldname": "is_orga_client",
    "fieldtype": "Check",
    "label": "Is Orga Client",
    "insert_after": "orga_client_section",
    "default": "0"
  },
  {
    "doctype": "Custom Field",
    "dt": "Contact",
    "fieldname": "orga_portal_enabled",
    "fieldtype": "Check",
    "label": "Portal Access",
    "insert_after": "is_orga_client",
    "depends_on": "eval:doc.is_orga_client",
    "default": "0"
  },
  {
    "doctype": "Custom Field",
    "dt": "Contact",
    "fieldname": "orga_client_column_break",
    "fieldtype": "Column Break",
    "insert_after": "orga_portal_enabled"
  },
  {
    "doctype": "Custom Field",
    "dt": "Contact",
    "fieldname": "orga_client_status",
    "fieldtype": "Select",
    "label": "Client Status",
    "options": "\nActive\nInactive\nPending",
    "insert_after": "orga_client_column_break",
    "depends_on": "eval:doc.is_orga_client"
  },
  {
    "doctype": "Custom Field",
    "dt": "Contact",
    "fieldname": "orga_project_count",
    "fieldtype": "Int",
    "label": "Linked Projects",
    "insert_after": "orga_client_status",
    "read_only": 1,
    "depends_on": "eval:doc.is_orga_client"
  }
]
